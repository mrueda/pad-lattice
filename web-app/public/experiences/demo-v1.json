{
  "schema_version": 1,
  "kind": "demo",
  "id": "multi-agent-guided-demo",
  "title": "Three Agents, One Surface",
  "initial_stage": "select_reviewer",
  "stages": [
    {
      "id": "select_reviewer",
      "prompt": {
        "eyebrow": "Three agents, one surface",
        "title": "The Reviewer needs you.",
        "detail": "Builder is running while Reviewer waits for a decision."
      },
      "guide_target": {"event": "select", "slot": 1, "action": null},
      "view": {
        "sessions": [
          {"slot": 0, "state": "running", "selected": true, "accent": "cyan", "label": "Builder"},
          {"slot": 1, "state": "waiting_for_approval", "selected": false, "accent": "magenta", "label": "Reviewer"},
          {"slot": 2, "state": "error", "selected": false, "accent": "lime", "label": "Tests"}
        ],
        "available_actions": []
      },
      "transitions": [
        {"event": "select", "slot": 1, "action": null, "next_stage": "approve_reviewer", "audio": "session_selected"}
      ],
      "enter_audio": "question",
      "terminal": false
    },
    {
      "id": "approve_reviewer",
      "prompt": {
        "eyebrow": "Permission requested",
        "title": "Approve the review.",
        "detail": "Approving lets Reviewer finish; Reject remains available as a recovery path."
      },
      "guide_target": {"event": "action", "slot": null, "action": "approve"},
      "view": {
        "sessions": [
          {"slot": 0, "state": "running", "selected": false, "accent": "cyan", "label": "Builder"},
          {"slot": 1, "state": "waiting_for_approval", "selected": true, "accent": "magenta", "label": "Reviewer"},
          {"slot": 2, "state": "error", "selected": false, "accent": "lime", "label": "Tests"}
        ],
        "available_actions": ["approve", "reject"]
      },
      "transitions": [
        {"event": "action", "slot": null, "action": "approve", "next_stage": "select_tests", "audio": "approve"},
        {"event": "action", "slot": null, "action": "reject", "next_stage": "recover_reviewer", "audio": "reject"}
      ],
      "enter_audio": "approval",
      "terminal": false
    },
    {
      "id": "recover_reviewer",
      "prompt": {
        "eyebrow": "Decision registered",
        "title": "The Reviewer was rejected.",
        "detail": "A cancelled agent can be brought back without changing sessions."
      },
      "guide_target": {"event": "action", "slot": null, "action": "retry"},
      "view": {
        "sessions": [
          {"slot": 0, "state": "running", "selected": false, "accent": "cyan", "label": "Builder"},
          {"slot": 1, "state": "cancelled", "selected": true, "accent": "magenta", "label": "Reviewer"},
          {"slot": 2, "state": "error", "selected": false, "accent": "lime", "label": "Tests"}
        ],
        "available_actions": ["retry"]
      },
      "transitions": [
        {"event": "action", "slot": null, "action": "retry", "next_stage": "select_tests", "audio": "retry"}
      ],
      "enter_audio": "cancelled",
      "terminal": false
    },
    {
      "id": "select_tests",
      "prompt": {
        "eyebrow": "Progress continues in parallel",
        "title": "The Tests need attention.",
        "detail": "Reviewer is complete, but Tests failed in the background."
      },
      "guide_target": {"event": "select", "slot": 2, "action": null},
      "view": {
        "sessions": [
          {"slot": 0, "state": "running", "selected": false, "accent": "cyan", "label": "Builder"},
          {"slot": 1, "state": "success", "selected": true, "accent": "magenta", "label": "Reviewer"},
          {"slot": 2, "state": "error", "selected": false, "accent": "lime", "label": "Tests"}
        ],
        "available_actions": []
      },
      "transitions": [
        {"event": "select", "slot": 2, "action": null, "next_stage": "retry_tests", "audio": "session_selected"}
      ],
      "enter_audio": "success",
      "terminal": false
    },
    {
      "id": "retry_tests",
      "prompt": {
        "eyebrow": "Failure is actionable",
        "title": "Retry the test agent.",
        "detail": "The selected failed agent now exposes its recovery action."
      },
      "guide_target": {"event": "action", "slot": null, "action": "retry"},
      "view": {
        "sessions": [
          {"slot": 0, "state": "running", "selected": false, "accent": "cyan", "label": "Builder"},
          {"slot": 1, "state": "success", "selected": false, "accent": "magenta", "label": "Reviewer"},
          {"slot": 2, "state": "error", "selected": true, "accent": "lime", "label": "Tests"}
        ],
        "available_actions": ["retry"]
      },
      "transitions": [
        {"event": "action", "slot": null, "action": "retry", "next_stage": "complete", "audio": "retry"}
      ],
      "enter_audio": "error",
      "terminal": false
    },
    {
      "id": "complete",
      "prompt": {
        "eyebrow": "One visual language",
        "title": "The agents form a constellation.",
        "detail": "Every color has an identity. Every shape has a state."
      },
      "guide_target": null,
      "view": {
        "sessions": [
          {"slot": 0, "state": "success", "selected": false, "accent": "cyan", "label": "Builder"},
          {"slot": 1, "state": "success", "selected": false, "accent": "magenta", "label": "Reviewer"},
          {"slot": 2, "state": "success", "selected": true, "accent": "lime", "label": "Tests"}
        ],
        "available_actions": []
      },
      "transitions": [],
      "enter_audio": "success",
      "terminal": true
    }
  ]
}
